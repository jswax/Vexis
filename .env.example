# Frontend / Next.js
# Used by `app/api/twitterai/*` proxy routes to reach the FastAPI service.
TWITTER_AI_URL=http://localhost:4001
# Optional: protects mutating TwitterAI endpoints (ingest/compute/export/recompute).
# If set, Next.js will forward this token to the FastAPI service.
TWITTERAI_TOKEN=

# Backend env lives in `backend/.env` — copy `backend/.env.example` to `backend/.env`.

