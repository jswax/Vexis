# TwitterAI — copy to .env and fill in values
DATABASE_URL=
# Optional: if set, POST endpoints require header `x-twitterai-token`
TWITTERAI_TOKEN=
# twitterapi.io (required for ingestion)
TWITTER_API_IO_KEY=
# Seconds between search requests (pagination). Default 5.1 = free-tier pacing. Use 0 if your plan allows faster calls.
# TWITTER_API_IO_REQUEST_DELAY_S=5.1
# Ingest: set false to skip ML predictions (faster bulk ingest; run backfill-predictions later).
# TWITTERAI_INGEST_PREDICTIONS=true

# Alpaca (required for outcome computation)
MARKET_DATA_PROVIDER=alpaca
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_STOCK_FEED=iex

# Benchmarks (optional)
DEFAULT_BENCHMARK_STOCK=SPY
DEFAULT_BENCHMARK_CRYPTO=BTCUSD

# Tuning
IMPACT_SCORE_MULTIPLIER=2.5
IMPACT_VOL_FLOOR=0.001
OFF_HOURS_IMPACT_MULTIPLIER=0.5

# Ingest: limit ticker spam / ETF holdings laundry lists
MATCH_MAX_TICKERS_PER_TWEET=12
MATCH_HOLDINGS_MIN_TICKERS=10
MATCH_HOLDINGS_MIN_CASHTAGS=8
MATCH_HOLDINGS_KEEP_TICKERS=QQQ,QQQM,SPY
