DATABASE_URL=postgres://vexis:password@127.0.0.1:5433/vexis_db?sslmode=disable
JWT_SECRET=change_me
PORT=8080
TRADINGVIEW_WEBHOOK_URL=https://example.com/webhook
ALERT_SECRET=change_me
ALLOWED_ORIGINS=http://localhost:3000,https://vexis-eight.vercel.app
GIN_MODE=debug

# Base URL for links in emails (use your Next.js origin)
APP_URL=http://localhost:3000

# With SendGrid: must match a verified Sender Identity (Single Sender or Domain) in the SendGrid dashboard.
# Values like noreply@localhost are rejected and mail will not be delivered.
FROM_EMAIL=noreply@yourdomain.com

# Local dev: skip Twilio; OTP logged and returned as dev_otp in JSON. Must be false in production.
SMS_BYPASS=true

# Local dev: skip SendGrid/SMTP; verify link logged and returned as dev_email_verify_url. Must be false in production.
EMAIL_BYPASS=true

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Use SendGrid API (recommended) OR SMTP below — required unless EMAIL_BYPASS=true.
SENDGRID_API_KEY=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=


# Admin account — set these once to auto-create an admin on startup.
# Remove ADMIN_PASSWORD after the first successful run (or leave it; it's idempotent).
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change_me_strong_password
ADMIN_PHONE=+15550000000

# Plan prices in USD — used for revenue dashboard calculation.
STANDARD_PLAN_PRICE=29.99
PREMIUM_PLAN_PRICE=79.99
